DATABASE_URL=
# (선택) 앱 런타임 전용. Supabase transaction pooler(6543) + ?pgbouncer=true 권장
# 미설정 시 session pooler(5432) URL을 자동으로 6543 transaction pooler로 전환한다.
DATABASE_URL_TRANSACTION=
# 자동 pooler 전환 비활성화: true
DATABASE_DISABLE_POOLER_UPGRADE=
# 앱 프로세스당 pg Pool 최대 연결 수 (기본 1)
DATABASE_POOL_MAX=1
# prisma migrate 전용 direct 연결 (Supabase direct host 또는 session pooler 5432)
DIRECT_DATABASE_URL=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
MASTER_ADMIN_EMAIL=
MASTER_ADMIN_PASSWORD=
SHOPLING_WMS_LOGIN_URL=https://a.shopling.co.kr/login.phtml
SHOPLING_WMS_LOGIN_ID=
SHOPLING_WMS_LOGIN_PASSWORD=
SHOPLING_WMS_LOGIN_TIMEOUT_MS=180000
SHOPLING_WMS_STEP_DELAY_MS=1200
SHOPLING_WMS_FRAME_WAIT_MS=60000
SHOPLING_WMS_POST_SAVE_PAUSE_MS=3000
SHOPLING_WMS_AUTOMATION_DISABLED=false
# 로컬: 비우면 OS temp. 영구 보관 시 예) ./data/runs
SHOPLING_WMS_WORK_DIR=
# Google Sheets (창고전송용 입고리스트 시트 복사)
# GOOGLE_SERVICE_ACCOUNT_KEY: 서비스 계정 JSON 전체 (한 줄). Vercel에서는 JSON 문자열 그대로 입력.
# GOOGLE_SHEET_ID: 스프레드시트 URL의 /d/ 와 /edit 사이 ID. GOOGLE_SHEET_URL 도 사용 가능.
# 스프레드시트를 서비스 계정 client_email 에 편집자로 공유해야 합니다.
GOOGLE_SERVICE_ACCOUNT_KEY=
GOOGLE_SHEET_ID=
GOOGLE_SHEET_URL=
