generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  master
  admin
}

enum AuditAction {
  profile_update
  password_change
  member_create
}

model Profile {
  id                    String                 @id
  email                 String                 @unique
  name                  String?
  role                  Role                   @default(admin)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  auditLogs             AuditLog[]
  coupangSellerAccounts CoupangSellerAccount[]
}

model CoupangSellerAccount {
  id          String   @id @default(cuid())
  displayName String
  isActive    Boolean  @default(true)
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy Profile @relation(fields: [createdById], references: [id], onDelete: Restrict)

  @@index([createdById])
  @@index([createdAt])
}

model AuditLog {
  id         String      @id @default(cuid())
  actorId    String
  action     AuditAction
  targetType String?
  targetId   String?
  metadata   Json?
  createdAt  DateTime    @default(now())

  actor Profile @relation(fields: [actorId], references: [id], onDelete: Cascade)

  @@index([actorId])
  @@index([action])
  @@index([createdAt])
}

model HealthCheck {
  id        String   @id @default(cuid())
  checkedAt DateTime @default(now())
}
